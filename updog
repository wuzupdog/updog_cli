errors_show() {
  if [ "$#" -eq 0 ]; then
    usage_error "errors show requires an error ID"
  fi

  case "$1" in
    -h | --help)
      print_errors_show_help
      exit 0
      ;;
  esac

  error_id=$1
  shift

  case "$error_id" in
    '' | *[!0-9]*) usage_error "error ID must be a positive integer: $error_id" ;;
  esac

  positive_id=$error_id
  while [ "${positive_id#0}" != "$positive_id" ]; do
    positive_id=${positive_id#0}
  done
  if [ -z "$positive_id" ]; then
    usage_error "error ID must be a positive integer: $error_id"
  fi

  show_since_set=0
  show_until_set=0
  show_limit_set=0
  show_offset_set=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h | --help)
        print_errors_show_help
        exit 0
        ;;
      --since)
        require_value "$1" "$#"
        show_since=$2
        show_since_set=1
        shift 2
        ;;
      --since=*)
        show_since=${1#*=}
        show_since_set=1
        shift
        ;;
      --until)
        require_value "$1" "$#"
        show_until=$2
        show_until_set=1
        shift 2
        ;;
      --until=*)
        show_until=${1#*=}
        show_until_set=1
        shift
        ;;
      --limit)
        require_value "$1" "$#"
        show_limit=$2
        show_limit_set=1
        shift 2
        ;;
      --limit=*)
        show_limit=${1#*=}
        show_limit_set=1
        shift
        ;;
      --offset)
        require_value "$1" "$#"
        show_offset=$2
        show_offset_set=1
        shift 2
        ;;
      --offset=*)
        show_offset=${1#*=}
        show_offset_set=1
        shift
        ;;
      --)
        shift
        if [ "$#" -gt 0 ]; then
          usage_error "unexpected argument: $1"
        fi
        ;;
      -*) usage_error "unknown errors show option: $1" ;;
      *) usage_error "unexpected argument for errors show: $1" ;;
    esac
  done

  set --
  [ "$show_since_set" -eq 0 ] || set -- "$@" --data-urlencode "since=$show_since"
  [ "$show_until_set" -eq 0 ] || set -- "$@" --data-urlencode "until=$show_until"
  [ "$show_limit_set" -eq 0 ] || set -- "$@" --data-urlencode "limit=$show_limit"
  [ "$show_offset_set" -eq 0 ] || set -- "$@" --data-urlencode "offset=$show_offset"

  api_get "/api/v1/errors/$error_id" "$@"
}

case "${1-}" in
  '' | -h | --help | help)
    print_help
    ;;
  -V | --version | version)
    printf 'updog %s\n' "$VERSION"
    ;;
  logs)
    shift
    case "${1-}" in
      search)
        shift
        logs_search "$@"
        ;;
      -h | --help | help) print_logs_help ;;
      '') usage_error "logs requires the search command" ;;
      *) usage_error "unknown logs command: $1" ;;
    esac
    ;;
  errors)
    shift
    case "${1-}" in
      search)
        shift
        errors_search "$@"
        ;;
      show)
        shift
        errors_show "$@"
        ;;
      -h | --help | help)
        print_errors_search_help
        printf '\n'
        print_errors_show_help
        ;;
      '') usage_error "errors requires the search or show command" ;;
      *) usage_error "unknown errors command: $1" ;;
    esac
    ;;
  *) usage_error "unknown command: $1" ;;
esac
