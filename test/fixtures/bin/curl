#!/bin/sh

: "${FAKE_CURL_ARGS_FILE:?FAKE_CURL_ARGS_FILE must be set}"
: "${FAKE_CURL_CONFIG_FILE:?FAKE_CURL_CONFIG_FILE must be set}"

: >"$FAKE_CURL_ARGS_FILE"
for fake_curl_arg do
  printf '%s\n' "$fake_curl_arg" >>"$FAKE_CURL_ARGS_FILE"
done

cat >"$FAKE_CURL_CONFIG_FILE"

if [ -n "${FAKE_CURL_STDERR-}" ]; then
  printf '%s\n' "$FAKE_CURL_STDERR" >&2
fi

if [ -n "${FAKE_CURL_BODY-}" ]; then
  printf '%s' "$FAKE_CURL_BODY"
fi

exit "${FAKE_CURL_STATUS:-0}"
